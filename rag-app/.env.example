# GraphRAG Environment Variables (Development)

# Backend Settings
PORT=8000
HOST=0.0.0.0
DEBUG=true
API_PREFIX=/api/v1

# Neo4j Settings
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_PORT=7687

# Storage
DATA_DIR=data

# Frontend Settings
FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:8000

# LLM Settings
LLM_API_KEY=your-openai-api-key
LLM_MODEL=gpt-3.5-turbo

# Embedding Settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=24
OLLAMA_BASE_URL=
NGROK_URL=
OLLAMA_EMBED_MODEL=nomic-embed-text-v2-moe
OLLAMA_TIMEOUT_SECONDS=120

# Mistral OCR Settings
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_API_BASE=https://api.mistral.ai/v1
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_INCLUDE_IMAGE_BASE64=false
MISTRAL_DELETE_REMOTE_FILE=true
MISTRAL_OCR_CHUNK_SIZE_PAGES=100
MISTRAL_API_TIMEOUT_SECONDS=300

# External automation pipeline
USE_JOB_AUTOMATION_PIPELINE=true
JOB_AUTOMATION_DIR=C:\Users\Admin\Downloads\job_automation
JOB_SCRIPT_TIMEOUT_SECONDS=7200
JOB_PYTHON_EXECUTABLE=
